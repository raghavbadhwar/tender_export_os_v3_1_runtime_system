# sources.export.yaml
# Export buyer and RFQ sources
# workflow: EXPORT
# Usage: Radar Agent reads this file to find export RFQ opportunities

sources:

  # --- Indian Export Portals ---

  - name: "India Business Portal (DGFT)"
    url: "https://www.indiabusinessportal.gov.in"
    type: "indian_government"
    workflow: EXPORT
    login_required: false
    paywalled: false
    scrape_type: "web"
    frequency: daily
    notes: "DGFT-backed buyer-seller match. Genuine foreign buyer RFQs."
    health_status: Working

  - name: "Indian Trade Portal (ITP)"
