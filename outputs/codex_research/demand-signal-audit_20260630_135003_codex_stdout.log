# sources.gov.yaml
# Government tender and public procurement sources for India
# workflow: GOV
# Usage: Radar Agent reads this file daily to determine which portals to check

sources:

  - name: "GeM — Government e-Marketplace"
    url: "https://gem.gov.in"
    type: "primary"
    workflow: GOV
    login_required: false
    paywalled: false
    api_available: true
    api_url: "https://bidplus.gem.gov.in/all-bids"
    scrape_type: "api_or_web"
    frequency: daily
    categories_supported: all
    notes: "Best source for small orders. Buyer verification built-in. L1 bidding."
    health_status: Working

  - name: "CPPP — Central Public Procurement Portal"
    url: "https://eprocure.gov.in/cppp/"
    type: "primary"
    workflow: GOV
    login_required: false
    paywalled: false
    api_available: false
    scrape_type: "web"
    frequency: daily
    notes: "Central Govt ministries and PSUs. Check corrigenda regularly."
    health_status: Working

  - name: "eProcure NIC"
    url: "https://eprocure.gov.in"
    type: "primary"
    workflow: GOV
    login_required: false
    paywalled: false
    api_available: false
    scrape_type: "web"
    frequency: daily
    notes: "Wide coverage of central and state tenders. Check bid documents carefully."
    health_status: Working

  - name: "Tender Tiger"
    url: "https://www.tendertiger.com"
    type: "aggregator"
    workflow: GOV
    login_required: true
    paywalled: true
    api_available: false
    scrape_type: "manual_check"
