    scrape_type: "web"
    frequency: weekly
    notes: "Heavy engineering. Requires technical experience."
    health_status: Working

  - name: "Tenders Info"
    url: "https://www.tendersinfo.com"
    type: "aggregator"
    workflow: GOV
