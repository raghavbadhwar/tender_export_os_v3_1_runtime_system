# approval_policy.yaml
# Approval Policy — defines what requires owner approval before any action is taken
# Usage: Approval Desk Agent checks this before routing any action card
# Principle: Agents prepare, draft, score, source. Humans approve external/money/legal actions.
# 2026-06-30 owner update: supplier outreach and portal login/signup/credential acquisition
# are covered by standing authorization inside the guardrails below.

# ══════════════════════════════════
# STANDING AUTHORIZATIONS — Owner-Preapproved Operating Actions
# ══════════════════════════════════

standing_authorizations:
  last_updated: "2026-06-30"
  owner_statement: "Owner granted standing approval for supplier outreach and portal login/signup/credential acquisition needed for Tender Export OS opportunity research."
  authorized_without_per_case_approval:
    - send_supplier_quote_request
    - send_supplier_clarification_request
    - send_supplier_follow_up
    - request_supplier_price_and_availability
    - portal_login_for_research
    - portal_signup_for_research
    - portal_credential_creation
    - portal_session_refresh_for_research
  credential_handling:
    storage: "macOS Keychain / approved secret store only; never CSV, YAML, Drive, reports, logs, prompts, or event payloads"
    log_format: "secret alias only, never secret value"
    otp_or_captcha: "may pause and request live owner assistance if an OTP, CAPTCHA, phone verification, or human-only identity challenge appears"
  hard_limits_still_requiring_specific_owner_approval:
    - send_buyer_rfq_reply
    - send_export_quotation
    - submit_tender_bid
    - upload_tender_documents
    - use_dsc
    - pay_emd_or_bid_security
    - pay_security_deposit
    - pay_advance_to_supplier
    - place_supplier_purchase_order
    - accept_payment_terms
    - commit_final_price
    - commit_delivery_timeline
    - confirm_hsn_itchs_classification
    - claim_country_of_origin
    - purchase_paid_subscription_or_portal_plan
    - make_legal_tax_origin_certification

# ══════════════════════════════════
# MODE A — Autopilot Research + Standing-Authorized Supplier/Portal Actions
# ══════════════════════════════════

mode_a_autopilot:
  description: "These actions can run without owner approval"
  allowed_actions:
    - scan_sources
    - extract_fields_from_pdf
    - read_tender_documents
    - score_opportunities
    - create_case_ids
    - fast_kill_scoring
    - deep_read_extraction
    - identify_candidate_suppliers
    - prepare_draft_pricing
    - prepare_draft_compliance_notes
    - prepare_draft_approval_cards
    - generate_daily_brief
    - update_master_cases_internal
    - update_agent_run_log
    - generate_case_reports
    - generate_supplier_shortlist
    - archive_rejected_cases
    - update_source_health
    - generate_pack_builder_draft
    - source_suppliers_research_only
    - generate_plugin_health_notes
    - generate_chatgpt_snapshot
    - generate_drive_sync_manifest
    - create_kanban_tasks_internal
    - produce_internal_artifact_drafts
    # Standing-authorized by owner on 2026-06-30; still record receipts and never include final commitments.
    - send_supplier_quote_request
    - send_supplier_clarification_request
    - send_supplier_follow_up
    - request_supplier_price_and_availability
    - portal_login_for_research
    - portal_signup_for_research
    - portal_credential_creation
    - portal_session_refresh_for_research

# ══════════════════════════════════
# MODE B — Approval-Gated Actions (Requires Owner Approval)
# ══════════════════════════════════

mode_b_approval_gated:
  description: "These actions MUST NOT proceed without explicit owner approval"
  gate_enforcement: strict  # Never bypass, even under time pressure

  approval_required_for:

    # send_supplier_quote_request moved to standing_authorizations on 2026-06-30.
    # It is now allowed without per-case approval when limited to quote/availability
    # requests and receipts are logged; buyer quotations, POs, payments, DSC,
    # bid uploads, and final commitments remain explicitly approval-gated.
    - action: "send_buyer_rfq_reply"
      reason: "External reply to buyer — creates business impression and potential obligation"
      approval_type: per_case
      card_required: true

    - action: "send_export_quotation"
      reason: "Price commitment to foreign buyer — legal and financial obligation"
      approval_type: per_case
      card_required: true

    - action: "submit_tender_bid"
      reason: "Irreversible action; requires DSC; creates binding legal obligation"
      approval_type: per_case
      card_required: true
      dsc_required: true

    - action: "upload_tender_documents"
      reason: "External portal action; may trigger bid acceptance"
      approval_type: per_case
      card_required: true

    - action: "commit_final_price"
      reason: "Price commitment — once sent, difficult to retract"
      approval_type: per_case
      card_required: true

    - action: "commit_delivery_timeline"
      reason: "Delivery promise — missed delivery = penalty"
      approval_type: per_case
      card_required: true

    - action: "accept_payment_terms"
      reason: "Legal and financial commitment"
      approval_type: per_case
      card_required: true

    - action: "confirm_hsn_itchs_classification"
      reason: "Wrong classification = customs penalty; requires export expert review"
      approval_type: per_case
      card_required: true
      expert_review_required: true

    - action: "claim_country_of_origin"
      reason: "Fraudulent origin claim = serious legal liability"
      approval_type: per_case
      card_required: true
      expert_review_required: true

    - action: "pay_emd_or_bid_security"
